[Unit]
Description=Watch for new StepMania dashboard bundles
After=multi-user.target

[Path]
# PathChanged fires after the file is closed (nginx finishes writing the
# WebDAV PUT), so we don't run on partial uploads.
PathChanged=/var/www/stepmania-incoming/sm-bundle.zip
Unit=sm-update.service

[Install]
WantedBy=multi-user.target
