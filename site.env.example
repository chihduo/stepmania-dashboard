# ---------------------------------------------------------------------------
# site.env — per-machine / per-person settings for the StepMania dashboard.
#
# Copy this file to  site.env  (same folder) and fill in your values:
#     cp site.env.example site.env
#
# site.env is the ONE place per-machine / personal values live, and it is
# gitignored — your values never enter version control; only this template is
# tracked and shared. Setting up a new machine (or someone else's copy) is
# just: copy this template to site.env, edit the values. Nothing else needs
# touching.
#
# Every value can also be overridden by an environment variable of the same
# name at runtime (the environment wins over this file).
#
# Format: KEY="value"  — plain shell assignments, comments on their own lines.
# Machines only need the keys relevant to their role (a WSL upload client
# needs SM_HOST; the server needs SM_LIVE_DIR; unused keys are ignored).
# ---------------------------------------------------------------------------

# Shown in the dashboard title/header: "<name>'s StepMania Play Dashboard".
# Leave empty for a plain "StepMania Play Dashboard".
SM_PLAYER_NAME=""

# Where the built dashboard is deployed (the nginx web root on the server).
# Used by build_dashboard.py auto-deploy and deploy.sh. Empty = no auto-deploy.
SM_LIVE_DIR="/var/www/stepmania"

# Public host of your dashboard server — hostname only, no scheme, no path.
# Drives the upload URL, the verify URL, the ~/.netrc machine name, and the
# "Visit:" link. Leave the placeholder on machines that don't upload or serve.
SM_HOST="example.com"

# (WSL upload client, optional) Windows StepMania 5.1 AppData dir, via /mnt/c.
# Auto-detected under /mnt/c/Users/*/AppData/Roaming/ when left unset.
#SM_APPDATA="/mnt/c/Users/You/AppData/Roaming/StepMania 5.1"
